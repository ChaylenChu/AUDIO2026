import { useEffect, useState } from 'react'
import { ChevronDown } from 'lucide-react'
import { useLocation } from 'react-router-dom'
import Works from './Works'
import About from './About'

export default function Home() {
  const location = useLocation()
  const [isHovered, setIsHovered] = useState(false) // 用于交互

  const scrollToSection = (id) => {
    const el = document.getElementById(id)
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }
  }

  const handleScrollToWorks = () => scrollToSection('works-section')

  useEffect(() => {
    const target = location.state && location.state.scrollTo
    if (target) {
      scrollToSection(target)
    }
  }, [location.state])

  return (
    /* 保持你最开始的父级结构，完全不动 */
    <div className="h-screen overflow-y-auto snap-y snap-mandatory bg-black">
      
      {/* --- Hero Section --- */}
      <section 
        className="relative h-screen snap-start flex flex-col justify-center bg-black overflow-hidden px-8 sm:px-16 md:px-24 lg:px-32"
        onMouseEnter={() => setIsHovered(true)}
        onMouseLeave={() => setIsHovered(false)}
      >
        
        {/* 🚀 插入图片层：使用 absolute 确保它不占任何空间，不撑开高度 */}
        <div className="absolute inset-0 z-0 flex justify-end items-center pointer-events-none">
          <div className="h-full w-full md:w-[60%] overflow-hidden"> 
            <img 
              src="assets/covers/hero.jpg" 
              alt="Hero" 
              className="h-full w-full object-cover transition-all duration-1000 ease-out"
              style={{
                objectPosition: 'right center',
                // 这里的滤镜组合是为了保证“温润”不黑
                filter: isHovered 
                  ? 'saturate(1) brightness(1.05) contrast(1)' 
                  : 'saturate(0.9) brightness(1) contrast(1)',
                opacity: 0.9,
                transform: isHovered ? 'scale(1.02)' : 'scale(1)'
              }}
            />
          </div>
        </div>

        {/* 🚀 插入遮罩层：让图片左侧和黑色背景完美融合 */}
        <div 
          className="absolute inset-0 z-[1] pointer-events-none"
          style={{
            background: 'linear-gradient(to right, #000 0%, #000 30%, transparent 85%)'
          }}
        />

        {/* 保持你最开始的文字内容结构，只把 z-index 提上来 */}
        <div className="relative z-10 max-w-6xl mx-auto w-full">
          <div className="max-w-xl">
            <h1 className="text-[clamp(3rem,10vw,7rem)] font-extralight leading-[1.04] tracking-tight text-white">
              <span className="block">CHAYLEN CHU</span>
            </h1>
            <p className="mt-4 pl-1 text-[11px] uppercase tracking-[0.7em] text-neutral-500">
              Sound Designer & Composer
            </p>
            <p className="mt-8 pl-1 text-sm sm:text-base text-neutral-400 font-light leading-relaxed max-w-md">
              Dedicated to composing and sculpting sound for immersive, generative audio-visual worlds.
            </p>
            <button
              type="button"
              onClick={handleScrollToWorks}
              className="mt-12 pl-1 inline-flex items-center gap-2 text-xs sm:text-[0.8rem] uppercase tracking-[0.26em] text-neutral-400 hover:text-white transition-colors group"
            >
              <span>explore works</span>
              <ChevronDown size={16} className="opacity-70 group-hover:translate-y-1 transition-transform" />
            </button>
          </div>
        </div>
      </section>

      {/* --- Works Section --- 保持你原来的样子 */}
      <section
        id="works-section"
        className="snap-start h-screen overflow-y-auto"
      >
        <Works />
      </section>

      {/* --- About Section --- 保持你原来的样子 */}
      <section
        id="about-section"
        className="snap-start h-screen"
      >
        <div className="h-full flex items-center justify-center px-5 sm:px-8 md:px-12">
          <div className="w-full max-w-3xl max-h-[80vh] overflow-y-auto">
            <About />
          </div>
        </div>
      </section>
    </div>
  )
}